# Neon Postgres Database (pooled connection string from Neon dashboard)
DATABASE_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"
# Direct (non-pooled) connection for migrations
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# JWT Secret - generate a strong random string for production
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# SMTP Email (required for password reset emails)
# For Gmail: use an App Password, not your regular password
# See: https://support.google.com/accounts/answer/185833
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Tales on 2 Wheels"

# Google Maps JavaScript API key — required for the Live Ride map.
# Enable in Google Cloud Console: "Maps JavaScript API" (always required),
# "Directions API" (required for the planned-route "Snap to roads" feature).
# Set HTTP referrer restrictions to your production + preview domains, and
# ensure billing is on.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Google Maps SERVER-side key — used by post-ride Elevation API, Roads API
# (snap-to-roads for recorded tracks), and Directions API (gap-fill).
# This is a SEPARATE key from NEXT_PUBLIC_GOOGLE_MAPS_API_KEY because referrer
# restrictions don't apply server-side. Enable in Google Cloud Console:
# "Elevation API", "Roads API", "Directions API". Restrict to those APIs;
# leave Application restrictions = None (or use IP allowlist).
# Optional: if unset, ride summaries omit elevation and the "Smooth & fill"
# admin action is disabled.
GOOGLE_MAPS_SERVER_API_KEY=""

# Vercel Blob — required for image uploads (avatars, ride posters, blog covers,
# ride post photos, motorcycle pictures). Provision a Blob store in the Vercel
# dashboard (Storage → Create → Blob); the BLOB_READ_WRITE_TOKEN env var is
# auto-set on Vercel deploys. For local dev, run `vercel env pull` to copy it.
BLOB_READ_WRITE_TOKEN=""

# Vercel KV — persistent storage for rate-limit counters across cold starts
# and Lambda instances. Provision a KV store in the Vercel project dashboard
# (Storage → Create → KV); the four env vars below are auto-populated on
# linked deployments. For local dev, leave unset — src/lib/rate-limit.ts
# falls back to an in-memory limiter. Auth routes (login / register / OTP)
# and the contact form use KV-backed limits; everything else stays
# in-memory for latency reasons.
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
KV_REST_API_READ_ONLY_TOKEN=""
KV_URL=""

# Sentry error tracking (free hobby tier: 5K errors + 10K transactions / month).
# Leave SENTRY_DSN / NEXT_PUBLIC_SENTRY_DSN unset to disable Sentry entirely —
# sentry.{client,server,edge}.config.ts short-circuit when the DSN is missing.
# SENTRY_ORG / SENTRY_PROJECT / SENTRY_AUTH_TOKEN are needed only on CI to
# upload source maps + tag releases; not required for runtime error capture.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# (Optional) External worker that renders the Relive-style ride video. The
# Next.js API forwards POST /api/rides/[id]/video/exports requests here; the
# worker renders the MP4 and PATCHes the export row back with the Blob URL.
# Leave unset to keep the export queued until a client-side renderer ships.
RIDE_VIDEO_WORKER_URL=""
RIDE_VIDEO_WORKER_SECRET=""
