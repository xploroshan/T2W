{
  "name": "t2w",
  "version": "1.0.0",
  "description": "This is a repo for T2W Website",
  "scripts": {
    "dev": "next dev",
    "build": "npx prisma generate && npx prisma db push && next build",
    "start": "next start",
    "db:push": "npx prisma db push",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "npx tsx scripts/seed-admins.ts && npx tsx scripts/seed-rider-profiles.ts && npx tsx scripts/seed-badges.ts",
    "db:reset": "npx prisma migrate reset --force",
    "db:studio": "npx prisma studio",
    "postinstall": "npx prisma generate && npx prisma db push --accept-data-loss && npx tsx scripts/seed-admins.ts && npx tsx scripts/seed-rider-profiles.ts && npx tsx scripts/seed-badges.ts && npx tsx scripts/seed-blogs-guidelines.ts"
  },
  "repository": {
    "type": "git",
    "url": "http://local_proxy@127.0.0.1:57774/git/machismo500/T2W"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
