generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  phone          String?
  password       String
  avatar         String?
  role           String   @default("rider") // rider | admin | superadmin
  joinDate       DateTime @default(now())
  isApproved     Boolean  @default(false)
  city           String?
  ridingExperience String?
  totalKm        Float    @default(0)
  ridesCompleted Int      @default(0)
  linkedRiderId  String?  // links to RiderProfile.id when email matches
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  motorcycles       Motorcycle[]
  earnedBadges      UserBadge[]
  rideRegistrations RideRegistration[]
  blogPosts         BlogPost[]
  notifications     Notification[]
  riderProfile      RiderProfile? @relation(fields: [linkedRiderId], references: [id])
}

// Rider profile data - the primary record for all riders (imported from Excel/admin)
// A User account may link to a RiderProfile when their emails match
model RiderProfile {
  id               String   @id @default(cuid())
  name             String
  email            String
  phone            String   @default("")
  address          String   @default("")
  emergencyContact String   @default("")
  emergencyPhone   String   @default("")
  bloodGroup       String   @default("")
  role             String   @default("rider") // rider | core_member | t2w_rider
  joinDate         DateTime @default(now())
  avatarUrl        String?
  ridesOrganized   Int      @default(0)
  sweepsDone       Int      @default(0)
  pilotsDone       Int      @default(0)
  mergedIntoId     String?  // if this profile was merged into another
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  linkedUsers      User[]
  participations   RideParticipation[]
  mergedInto       RiderProfile?  @relation("ProfileMerge", fields: [mergedIntoId], references: [id])
  mergedFrom       RiderProfile[] @relation("ProfileMerge")

  @@index([email])
  @@index([mergedIntoId])
}

// Tracks which riders participated in which rides with points
model RideParticipation {
  id             String   @id @default(cuid())
  riderProfileId String
  rideId         String
  points         Float    @default(5)
  droppedOut     Boolean  @default(false)
  createdAt      DateTime @default(now())

  riderProfile RiderProfile @relation(fields: [riderProfileId], references: [id], onDelete: Cascade)
  ride         Ride         @relation(fields: [rideId], references: [id], onDelete: Cascade)

  @@unique([riderProfileId, rideId])
}

model Motorcycle {
  id       String  @id @default(cuid())
  make     String
  model    String
  year     Int
  cc       Int
  color    String
  nickname String?
  imageUrl String?
  userId   String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Badge {
  id          String @id @default(cuid())
  tier        String @unique // SILVER | GOLD | PLATINUM | DIAMOND | ACE | CONQUEROR
  name        String
  description String
  minKm       Float
  icon        String
  color       String

  earnedBy UserBadge[]
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  badgeId    String
  earnedDate DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model Ride {
  id               String   @id @default(cuid())
  title            String
  rideNumber       String   @unique
  type             String   // day | weekend | multi-day | expedition
  status           String   @default("upcoming") // upcoming | ongoing | completed | cancelled
  startDate        DateTime
  endDate          DateTime
  startLocation    String
  startLocationUrl String?
  endLocation      String
  endLocationUrl   String?
  route            String   // JSON array stored as string
  distanceKm       Float
  maxRiders        Int
  difficulty       String   // easy | moderate | challenging | extreme
  description      String
  highlights       String   // JSON array stored as string
  posterUrl        String?
  fee              Float
  leadRider        String
  sweepRider       String
  organisedBy      String?
  accountsBy       String?
  meetupTime       String?
  rideStartTime    String?
  startingPoint    String?
  riders           String?  // JSON array of rider names
  regFormSettings  String?  // JSON: per-ride registration form overrides
  regOpenCore      DateTime? // When registration opens for core_member
  regOpenT2w       DateTime? // When registration opens for t2w_rider
  regOpenRider     DateTime? // When registration opens for rider / guest
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  registrations    RideRegistration[]
  participations   RideParticipation[]
  liveSession      LiveRideSession?
  ridePosts        RidePost[]
}

model RideRegistration {
  id                    String   @id @default(cuid())
  userId                String
  rideId                String
  riderName             String
  address               String   @default("")
  email                 String
  phone                 String
  emergencyContactName  String   @default("")
  emergencyContactPhone String   @default("")
  bloodGroup            String   @default("")
  referredBy            String   @default("")
  foodPreference        String   @default("")
  ridingType            String   @default("")
  vehicleModel          String   @default("")
  vehicleRegNumber      String   @default("")
  tshirtSize            String   @default("")
  agreedCancellationTerms Boolean @default(false)
  agreedIndemnity       Boolean  @default(false)
  paymentScreenshot     String   @default("") @db.Text
  upiTransactionId      String   @default("")
  registeredAt          DateTime @default(now())
  confirmationCode      String?
  approvalStatus        String   @default("pending") // pending | confirmed | rejected

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  ride Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)

  @@unique([userId, rideId])
}

model BlogPost {
  id             String   @id @default(cuid())
  title          String
  excerpt        String
  content        String
  authorId       String?
  authorName     String
  authorAvatar   String?
  publishDate    DateTime @default(now())
  coverImage     String?
  tags           String   // JSON array stored as string
  type           String   // official | personal
  isVlog         Boolean  @default(false)
  videoUrl       String?
  readTime       Int
  likes          Int      @default(0)
  approvalStatus String   @default("approved") // pending | approved | rejected
  approvedBy     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([approvalStatus])
}

model Notification {
  id      String   @id @default(cuid())
  title   String
  message String
  type    String   // info | warning | success | ride
  date    DateTime @default(now())
  isRead  Boolean  @default(false)
  userId  String?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Otp {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      String   // email_verify | password_reset
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, type])
}

model Guideline {
  id       String @id @default(cuid())
  title    String
  content  String
  category String // group | general | safety | maintenance
  icon     String
}

model LiveRideSession {
  id            String    @id @default(cuid())
  rideId        String    @unique
  status        String    @default("waiting") // waiting | live | paused | ended
  startedAt     DateTime?
  endedAt       DateTime?
  startedBy     String    // userId who started the session
  leadRiderId   String?   // userId of lead rider
  sweepRiderId  String?   // userId of sweep rider
  plannedRoute  String?   // JSON: [{lat,lng},...] for deviation detection
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  ride      Ride               @relation(fields: [rideId], references: [id], onDelete: Cascade)
  locations LiveRideLocation[]
  breaks    LiveRideBreak[]
}

model LiveRideLocation {
  id         String   @id @default(cuid())
  sessionId  String
  userId     String
  lat        Float
  lng        Float
  speed      Float?   // km/h
  heading    Float?   // degrees
  accuracy   Float?   // meters
  isDeviated Boolean  @default(false)
  recordedAt DateTime @default(now())

  session LiveRideSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, userId])
  @@index([sessionId, recordedAt])
}

model LiveRideBreak {
  id        String    @id @default(cuid())
  sessionId String
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  reason    String?

  session LiveRideSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Content {
  id          String   @id @default(cuid())
  title       String
  type        String   // Brand | Media | Document
  status      String   @default("draft") // published | draft
  lastUpdated DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RidePost {
  id             String   @id @default(cuid())
  rideId         String
  authorId       String?
  authorName     String
  content        String   @db.Text
  images         String?  // JSON array of image URLs
  approvalStatus String   @default("pending") // pending | approved | rejected
  approvedBy     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ride Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)

  @@index([rideId])
  @@index([approvalStatus])
}

model ActivityLog {
  id              String   @id @default(cuid())
  action          String   // ride_created | user_deleted | role_changed | etc.
  performedBy     String
  performedByName String
  targetId        String
  targetName      String
  details         String?
  rollbackData    String?  @db.Text // JSON for undo
  createdAt       DateTime @default(now())

  @@index([createdAt])
}

model SiteSettings {
  id    String @id @default(cuid())
  key   String @unique  // e.g. "reg_form_settings", "about_content"
  value String @db.Text // JSON value
  updatedAt DateTime @updatedAt
}
