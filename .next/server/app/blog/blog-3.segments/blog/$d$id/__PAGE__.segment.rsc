2:T411,{"@context":"https://schema.org","@type":"BlogPosting","headline":"Tales of Thailand: T2W Goes International Again","description":"1,200 km through the Land of Smiles. From Bangkok to Chiang Mai on two wheels.","articleBody":"After Nepal, T2W set its sights on Southeast Asia. Ride #023 - Tales of Thailand 2025, spanning October 31 to November 10, covered 1,200 km from Bangkok to Chiang Mai. Organised by Roshan Manuel, this expedition explored Thai temples, mountain roads, and street food culture on two wheels.","datePublished":"2025-11-20","dateModified":"2025-11-20","author":{"@type":"Person","name":"Jay Trivedi"},"publisher":{"@type":"Organization","name":"Tales on 2 Wheels","url":"https://taleson2wheels.com","logo":{"@type":"ImageObject","url":"https://taleson2wheels.com/logo.png"}},"mainEntityOfPage":{"@type":"WebPage","@id":"https://taleson2wheels.com/blog/blog-3"},"image":"https://taleson2wheels.com/og-image.jpg","keywords":"thailand, expedition, international","wordCount":48,"timeRequired":"PT10M","inLanguage":"en-IN"}0:{"buildId":"5RLXb5TwnaRLfE1YqusAj","rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","$L3",null,{"blogId":"blog-3"}]],null,["$","$L4",null,{"children":["$","$5",null,{"name":"Next.MetadataOutlet","children":"$@6"}]}]]}],"loading":null,"isPartial":false}
