2:T4a6,{"@context":"https://schema.org","@type":"BlogPosting","headline":"Himalayan Tales: 19 Days from Manali to Leh","description":"The T2W Himalayan expedition - 3,300 km through the highest motorable passes in the world. A ride that changed everything.","articleBody":"It started at 2:30 AM at Bangalore International Airport. 19 days, 3,300 km, and some of the most breathtaking landscapes on Earth. From Rohtang to Khardung La, through Pangong Lake and Nubra Valley - this is the story of T2W Ride #004, Himalayan Tales. Organised by Roshan Manuel with Suren as pilot and Harish Mysuru on sweep, this expedition tested every rider to their limits and beyond.","datePublished":"2024-07-15","dateModified":"2024-07-15","author":{"@type":"Person","name":"Roshan Manuel"},"publisher":{"@type":"Organization","name":"Tales on 2 Wheels","url":"https://taleson2wheels.com","logo":{"@type":"ImageObject","url":"https://taleson2wheels.com/logo.png"}},"mainEntityOfPage":{"@type":"WebPage","@id":"https://taleson2wheels.com/blog/blog-1"},"image":"https://taleson2wheels.com/og-image.jpg","keywords":"himalayan, expedition, ladakh, adventure","wordCount":67,"timeRequired":"PT15M","inLanguage":"en-IN"}0:{"buildId":"1mG1er8fbPUSuzEEu6XQt","rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","$L3",null,{"blogId":"blog-1"}]],null,["$","$L4",null,{"children":["$","$5",null,{"name":"Next.MetadataOutlet","children":"$@6"}]}]]}],"loading":null,"isPartial":false}
