2:T447,{"@context":"https://schema.org","@type":"BlogPosting","headline":"Nepal Tales: Riding Through the Himalayas","description":"1,950 km across Nepal - from Kathmandu to Pokhara and beyond. T2W's first international expedition.","articleBody":"T2W Ride #016 took us across the border into Nepal for 18 incredible days. Starting May 1st 2025, we rode through Kathmandu valley, the Annapurna circuit roads, Pokhara's lakeside, and the winding mountain passes of the Himalayas. An international expedition that pushed boundaries and created memories for a lifetime.","datePublished":"2025-06-01","dateModified":"2025-06-01","author":{"@type":"Person","name":"Roshan Manuel"},"publisher":{"@type":"Organization","name":"Tales on 2 Wheels","url":"https://taleson2wheels.com","logo":{"@type":"ImageObject","url":"https://taleson2wheels.com/logo.png"}},"mainEntityOfPage":{"@type":"WebPage","@id":"https://taleson2wheels.com/blog/blog-2"},"image":"https://taleson2wheels.com/og-image.jpg","keywords":"nepal, expedition, international, adventure","wordCount":49,"timeRequired":"PT12M","inLanguage":"en-IN"}0:{"buildId":"5RLXb5TwnaRLfE1YqusAj","rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","$L3",null,{"blogId":"blog-2"}]],null,["$","$L4",null,{"children":["$","$5",null,{"name":"Next.MetadataOutlet","children":"$@6"}]}]]}],"loading":null,"isPartial":false}
