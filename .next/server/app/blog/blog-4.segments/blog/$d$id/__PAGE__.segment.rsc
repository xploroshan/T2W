2:T437,{"@context":"https://schema.org","@type":"BlogPosting","headline":"Kambala 3.0: The Mangalore Run","description":"800 km, 3 days, and the thrill of witnessing the ancient Kambala buffalo race in coastal Karnataka.","articleBody":"T2W Ride #013 - Kambala 3.0 was a special one. Organised by Jay Trivedi, this 3-day ride from Bangalore to Mangalore covered 800 km and timed perfectly with the traditional Kambala buffalo race. Starting from Parle-G Toll at 5 AM with Jay as pilot and Harish Mysuru on sweep, we experienced the best of coastal Karnataka.","datePublished":"2025-03-01","dateModified":"2025-03-01","author":{"@type":"Person","name":"Harish Mysuru"},"publisher":{"@type":"Organization","name":"Tales on 2 Wheels","url":"https://taleson2wheels.com","logo":{"@type":"ImageObject","url":"https://taleson2wheels.com/logo.png"}},"mainEntityOfPage":{"@type":"WebPage","@id":"https://taleson2wheels.com/blog/blog-4"},"image":"https://taleson2wheels.com/og-image.jpg","keywords":"coastal, kambala, mangalore, culture","wordCount":56,"timeRequired":"PT8M","inLanguage":"en-IN"}0:{"buildId":"1mG1er8fbPUSuzEEu6XQt","rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","$L3",null,{"blogId":"blog-4"}]],null,["$","$L4",null,{"children":["$","$5",null,{"name":"Next.MetadataOutlet","children":"$@6"}]}]]}],"loading":null,"isPartial":false}
