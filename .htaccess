DirectoryIndex disabled

RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Pass all requests to the Node.js app via Passenger
PassengerEnabled On
PassengerAppType node
PassengerStartupFile server.js
PassengerNodejs /home/bpph7k2lydye/.nvm/versions/node/v20.20.1/bin/node
PassengerAppRoot /home/bpph7k2lydye/repositories/T2W
PassengerFriendlyErrorPages on
